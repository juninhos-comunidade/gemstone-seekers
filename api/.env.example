# ============================================
# GEMSTONE SEEKERS - ENVIRONMENT VARIABLES
# ============================================

# --------------------------------------------
# COMPOSE
# Automatically loads base compose + override (dev)
# In prod, override via -f flags in the command or CI/CD
# --------------------------------------------
COMPOSE_FILE=docker/compose.yaml:docker/compose.override.yaml

# --------------------------------------------
# APPLICATION
# --------------------------------------------
SERVER_PORT=8080
APPLICATION_VERSION=1.0.0-SNAPSHOT
SPRING_PROFILES_ACTIVE=local

# --------------------------------------------
# LOGGING
# --------------------------------------------
LOGGING_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3

# --------------------------------------------
# DATABASE (PostgreSQL)
# --------------------------------------------
POSTGRES_IMAGE=postgres:18-alpine
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gemstone_seekers_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --------------------------------------------
# SECURITY & JWT
# --------------------------------------------
JWT_SECRET=your-256-bit-secret-key-here-must-be-at-least-32-characters-long-for-security
JWT_ACCESS_TOKEN_EXPIRATION=86400000
JWT_REFRESH_TOKEN_EXPIRATION=604800000
RATE_LIMIT_ENABLED=true

# --------------------------------------------
# DOCKER & CI/CD
# --------------------------------------------
APP_IMAGE=gemstoneseekers/gemstone-seekers-api
DOCKER_BUILD_SKIP=false

# --------------------------------------------
# PROD RESOURCE LIMITS
# --------------------------------------------
APP_CPU_LIMIT=1.0
APP_MEMORY_LIMIT=600M
APP_MEMORY_RESERVATION=400M
POSTGRES_CPU_LIMIT=0.5
POSTGRES_MEMORY_LIMIT=512M
POSTGRES_MEMORY_RESERVATION=256M
